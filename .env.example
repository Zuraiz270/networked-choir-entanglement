# SNA-OSN-M Project 8 — environment configuration template.
# Copy to `.env` (gitignored) and fill in values for local development.

# --- Paths ---
# Root of raw/ tree (immutable source data).
CE_RAW_DIR=./raw

# Root for runtime-produced processed artefacts.
CE_PROCESSED_DIR=./processed

# Root for feature tables.
CE_FEATURES_DIR=./features

# Root for results (E(t) tables, graphs, figures).
CE_RESULTS_DIR=./results

# --- Network / data ---
# YouTube scraper rate limit (requests per minute). Dropped to 2 on HTTP 429.
CE_YT_RATE_LIMIT=10

# --- Compute ---
# Number of parallel workers for feature extraction (-1 = all cores).
CE_NUM_WORKERS=-1

# --- Secrets (NEVER commit .env; .env.example only) ---
# GitHub token for CI integrations (optional).
# GITHUB_TOKEN=
